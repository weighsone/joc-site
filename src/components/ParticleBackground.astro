---
// ParticleBackground.astro - Ambient particle background animation with subtle mouse parallax
---

<canvas id="particle-canvas" aria-hidden="true"></canvas>

<script>
  // Inline script to ensure it runs after page load
  // Check for reduced motion preference
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  
  if (!prefersReducedMotion) {
    const canvas = document.getElementById('particle-canvas');
    if (canvas) {
      const ctx = canvas.getContext('2d');
      let particles = [];
      let animationId;

      // Mouse parallax state
      let mouseX = 0;
      let mouseY = 0;
      let targetOffsetX = 0;
      let targetOffsetY = 0;
      let currentOffsetX = 0;
      let currentOffsetY = 0;

      // Configuration
      const CONFIG = {
        particleCount: 50,
        minSize: 2,
        maxSize: 4,
        minSpeed: 0.1,
        maxSpeed: 0.3,
        minOpacity: 0.2,
        maxOpacity: 0.5,
        color: '#52b788',
        connectDistance: 120,
        lineOpacity: 0.15,
        // Parallax settings
        parallaxStrength: 15,      // Maximum pixel offset (increase for stronger effect, 10-30 recommended)
        parallaxEasing: 0.05,      // Smoothing factor (0.05 = smooth, 0.1 = snappier)
        parallaxDepthVariation: 0.6, // How much particle speed affects parallax (0-1, higher = more depth)
      };

      // Resize canvas to fill window
      function resizeCanvas() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      // Mouse move handler with normalization
      function handleMouseMove(e) {
        // Normalize mouse position to -1 to +1 range (center = 0,0)
        mouseX = (e.clientX / window.innerWidth) * 2 - 1;
        mouseY = (e.clientY / window.innerHeight) * 2 - 1;

        // Calculate target offset
        targetOffsetX = mouseX * CONFIG.parallaxStrength;
        targetOffsetY = mouseY * CONFIG.parallaxStrength;
      }

      // Update parallax offset with easing
      function updateParallaxOffset() {
        currentOffsetX += (targetOffsetX - currentOffsetX) * CONFIG.parallaxEasing;
        currentOffsetY += (targetOffsetY - currentOffsetY) * CONFIG.parallaxEasing;
      }

      // Particle class
      class Particle {
        constructor() {
          this.baseX = 0;
          this.baseY = 0;
          this.reset();
          this.x = Math.random() * canvas.width;
          this.y = Math.random() * canvas.height;
          this.baseX = this.x;
          this.baseY = this.y;
        }

        reset() {
          this.x = Math.random() * canvas.width;
          this.y = Math.random() * canvas.height;
          this.baseX = this.x;
          this.baseY = this.y;
          this.vx = (Math.random() - 0.5) * (CONFIG.maxSpeed - CONFIG.minSpeed) + CONFIG.minSpeed;
          this.vy = (Math.random() - 0.5) * (CONFIG.maxSpeed - CONFIG.minSpeed) + CONFIG.minSpeed;
          this.radius = Math.random() * (CONFIG.maxSize - CONFIG.minSize) + CONFIG.minSize;
          this.opacity = Math.random() * (CONFIG.maxOpacity - CONFIG.minOpacity) + CONFIG.minOpacity;
          
          // Calculate parallax depth based on particle speed
          // Slower particles = less parallax (appear closer)
          // Faster particles = more parallax (appear farther)
          const speedMagnitude = Math.sqrt(this.vx * this.vx + this.vy * this.vy);
          const normalizedSpeed = (speedMagnitude - CONFIG.minSpeed) / (CONFIG.maxSpeed - CONFIG.minSpeed);
          this.parallaxDepth = 0.3 + (normalizedSpeed * CONFIG.parallaxDepthVariation);
        }

        update() {
          // Update base position with velocity
          this.baseX += this.vx;
          this.baseY += this.vy;

          // Wrap around screen edges
          if (this.baseX < -10) this.baseX = canvas.width + 10;
          if (this.baseX > canvas.width + 10) this.baseX = -10;
          if (this.baseY < -10) this.baseY = canvas.height + 10;
          if (this.baseY > canvas.height + 10) this.baseY = -10;

          // Apply parallax offset based on particle depth
          this.x = this.baseX + (currentOffsetX * this.parallaxDepth);
          this.y = this.baseY + (currentOffsetY * this.parallaxDepth);
        }

        draw() {
          ctx.beginPath();
          ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
          ctx.fillStyle = hexToRGBA(CONFIG.color, this.opacity);
          ctx.fill();
        }
      }

      function hexToRGBA(hex, alpha) {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
      }

      function drawConnections() {
        if (CONFIG.connectDistance === 0) return;

        for (let i = 0; i < particles.length; i++) {
          for (let j = i + 1; j < particles.length; j++) {
            const dx = particles[i].x - particles[j].x;
            const dy = particles[i].y - particles[j].y;
            const distance = Math.sqrt(dx * dx + dy * dy);

            if (distance < CONFIG.connectDistance) {
              const opacity = (1 - distance / CONFIG.connectDistance) * CONFIG.lineOpacity;
              ctx.beginPath();
              ctx.moveTo(particles[i].x, particles[i].y);
              ctx.lineTo(particles[j].x, particles[j].y);
              ctx.strokeStyle = hexToRGBA(CONFIG.color, opacity);
              ctx.lineWidth = 1;
              ctx.stroke();
            }
          }
        }
      }

      function animate() {
        // Update parallax offset with smooth easing
        updateParallaxOffset();

        ctx.clearRect(0, 0, canvas.width, canvas.height);

        particles.forEach(particle => {
          particle.update();
          particle.draw();
        });

        drawConnections();

        animationId = requestAnimationFrame(animate);
      }

      function init() {
        resizeCanvas();
        
        particles = [];
        for (let i = 0; i < CONFIG.particleCount; i++) {
          particles.push(new Particle());
        }

        // Add mouse move listener
        window.addEventListener('mousemove', handleMouseMove, { passive: true });

        animate();
      }

      window.addEventListener('resize', () => {
        resizeCanvas();
        if (Math.abs(canvas.width - window.innerWidth) > 100) {
          particles.forEach(p => p.reset());
        }
      });

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }

      window.addEventListener('beforeunload', () => {
        if (animationId) {
          cancelAnimationFrame(animationId);
        }
        window.removeEventListener('mousemove', handleMouseMove);
      });
    }
  }
</script>

<style>
  #particle-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    #particle-canvas {
      opacity: 0;
      display: none;
    }
  }
</style>