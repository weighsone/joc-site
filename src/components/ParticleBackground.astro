---
// ParticleBackground.astro - Ambient particle background animation
---

<canvas id="particle-canvas" aria-hidden="true"></canvas>

<script src={`${import.meta.env.BASE_URL}scripts/particles.js`}></script>

<style>
  #particle-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.3s ease;
  }

  /* Respect user's motion preferences */
  @media (prefers-reduced-motion: reduce) {
    #particle-canvas {
      opacity: 0;
      display: none;
    }
  }
</style>
